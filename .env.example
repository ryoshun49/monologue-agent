# Anthropic API Key (optional — OAuth via claude-auth volume is primary)
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# Heartbeat interval in minutes (default: 30)
HEARTBEAT_INTERVAL_MIN=30

# Max budget per heartbeat in USD (default: 0.30)
MAX_BUDGET_USD=0.30

# Notion API (optional — for Notion context ingestion)
NOTION_API_KEY=ntn_xxxxx
# Notion DB IDs (optional — leave empty to skip specific DBs)
NOTION_DB_DAILY_NOTES=
NOTION_DB_WORK_CAPTURE=
NOTION_DB_BACKLOG=

# TASKS.md host path (default: ./data/TASKS.md)
# TASKS_FILE_HOST=~/Documents/TASKS/TASKS.md

# Discord Bot (required for discord-bot service)
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CHANNEL_ID=your-channel-id
